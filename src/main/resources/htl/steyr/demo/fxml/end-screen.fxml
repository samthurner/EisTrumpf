<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="htl.steyr.demo.controller.EndScreenController"
      fx:id="root"
      alignment="CENTER"
      spacing="70"
      styleClass="end-screen">

    <padding>
        <Insets top="100" bottom="100" left="100" right="100"/>
    </padding>

    <Label fx:id="winnerLabel"
           text="Gewinner: Spieler"
           style="-fx-font-size: 50px; -fx-font-weight: bold;"
           styleClass="winner-text"/>

    <Label fx:id="infoLabel"
           text="Du hast gewonnen!"
           style="-fx-font-size: 30px;"
           styleClass="info-text"/>

    <Button fx:id="backToMenuButton"
            text="Zurück zum Menü"
            onAction="#onBackToMenuClicked"
            style="-fx-font-size: 20px; -fx-padding: 10 30;"
            styleClass="menu-button"/>

</VBox>
