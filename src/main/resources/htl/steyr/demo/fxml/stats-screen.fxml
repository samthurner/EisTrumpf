<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="htl.steyr.demo.controller.StatsScreenController">

    <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" styleClass="Label-darkmode" text="Statistiken" AnchorPane.leftAnchor="40" AnchorPane.topAnchor="40" />

    <Label fx:id="gamesPlayedLabel" prefHeight="19.0" prefWidth="270.0" style="-fx-font-size: 13px;" styleClass="Label-darkmode" text="gespielte Spiele:" AnchorPane.leftAnchor="60" AnchorPane.topAnchor="110" />

    <Label fx:id="gamesWonLabel" prefHeight="19.0" prefWidth="270.0" style="-fx-font-size: 13px;" styleClass="Label-darkmode" text="gewonnene Spiele:" AnchorPane.leftAnchor="60" AnchorPane.topAnchor="150" />

    <Label fx:id="winrateLabel" prefHeight="19.0" prefWidth="270.0" style="-fx-font-size: 13px;" styleClass="Label-darkmode" text="Win-Rate:" AnchorPane.leftAnchor="60" AnchorPane.topAnchor="190" />

    <Label fx:id="winStreakLabel" prefHeight="19.0" prefWidth="270.0" style="-fx-font-size: 13px;" styleClass="Label-darkmode" text="Längste Winstreak:" AnchorPane.leftAnchor="60" AnchorPane.topAnchor="230" />

    <Button fx:id="okButton" layoutX="548.0" layoutY="356.0" onAction="#onOkClicked" prefHeight="27.0" prefWidth="59.0" style="-fx-font-size: 13px;" text="OK" AnchorPane.bottomAnchor="15.0" AnchorPane.rightAnchor="14.0" />
   <Label fx:id="gameTimeStatLabel" layoutX="60.0" layoutY="267.0" prefHeight="18.0" prefWidth="269.0" styleClass="Label-darkmode" text="Spielzeit:" />

</AnchorPane>
